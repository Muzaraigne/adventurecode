def lecture(fichier : str)->int : 
    """
    Lit le contenu d'un fichier et dis au père noël la ou il doit aller pour livrer son cadeau
    
    :fichier : la chaine a lire
    :return: l'etage ou il doit allé 
    """
    res =0 
    for i in range(0, len(fichier)):
        c= fichier[i]
        if c == '(':
            res += 1
        elif c == ')':
            res -= 1
        
        
    return res

def lecture2(fichier : str)->int : 
    """
    Lit le contenu d'un fichier et dis au père noël la ou il doit aller pour livrer son cadeau
    mais en plus il dit a quel moment il est tombé dans le sous-sol
    
    :fichier : la chaine a lire
    :return: l'etage ou il doit allé et le moment ou il est tombé dans le sous-sol
    """
    res =0 
    for i in range(0, len(fichier)):
        c= fichier[i]
        if c == '(':
            res += 1
        elif c == ')':
            res -= 1
        
        if res < 0:
            return i + 1
        
    return -1

