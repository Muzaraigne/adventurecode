def is_nice_string(chaine):
    return (containsVoy(chaine) and containsDoubleLetter(chaine) and not containsBadStrings(chaine))

def count_nice_strings(strings):
    count = 0
    for string in strings:
        if is_nice_string(string):
            count += 1
    return count

